{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2022"],
    "declaration": true,
    "outDir": "docs",
    "rootDir": "web"
  },
  "include": ["web/**/*.ts"]
}
